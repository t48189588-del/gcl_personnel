{
  "name": "GCL Personnel Cloud Box",
  "image": "ghcr.io/cirruslabs/flutter:3.24.0",
  "remoteUser": "root",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true
    }
  },
  "updateContentCommand": "flutter pub get",
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.flutter",
        "Dart-Code.dart"
      ]
    }
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "GCL Personnel UI",
      "onAutoForward": "openPreview"
    }
  }
}