{
  "name": "Flutter Sandbox Workspace",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "dart.flutterSdkPath": "/home/vscode/flutter"
      },
      "extensions": [
        "dart-code.dart-code",
        "dart-code.flutter",
        "yzhang.markdown-all-in-one", // Markdown Shortcuts/Formatting
        "shaydulin.vscode-markdown-formatter", // Markdown Formatter
        "ritwickdey.LiveServer"    // Live Server for Static Previews
      ]
    }
  },
  "remoteUser": "vscode",
  "updateContentCommand": "flutter pub get",
  // Port 8080 will serve the hot-reloading Flutter Web app
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Flutter Web App",
      "onAutoForward": "openPreview"
    }
  }
}